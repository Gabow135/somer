# SOMER Configuration

# LLM Provider
ANTHROPIC_API_KEY=your_api_key_here
SOMER_MODEL=claude-3-5-sonnet-20241022

# Memory - Redis
REDIS_URL=redis://localhost:6379/0

# Memory - SQLite
SQLITE_PATH=./data/somer.db

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Execution
SOMER_STRICT_MODE=true
SOMER_MAX_RETRIES=3
SOMER_TIMEOUT_SECONDS=300

# =============================================================================
# Omnichannel Configuration
# =============================================================================

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789,987654321
TELEGRAM_ADMIN_USERS=123456789
TELEGRAM_OPERATOR_USERS=
TELEGRAM_ENABLE_GROUPS=false

# WhatsApp (optional) — Provider: "twilio" or "meta"
WHATSAPP_PROVIDER=twilio
# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886
# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
# Access control
WHATSAPP_ALLOWED_USERS=+1234567890
WHATSAPP_ADMIN_USERS=+1234567890

# Discord Bot (optional)
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_ALLOWED_USERS=123456789
DISCORD_ADMIN_USERS=123456789

# =============================================================================
# Integrations / Skills
# =============================================================================

# Trello (optional)
TRELLO_API_KEY=your_api_key_here
TRELLO_TOKEN=your_token_here
TRELLO_BOARD_ID=your_board_id_here

# Notion (optional)
NOTION_API_KEY=your_integration_token_here
NOTION_DEFAULT_DATABASE=your_database_id_here

# GitHub (optional)
GITHUB_TOKEN=your_personal_access_token_here

# Web Search (optional)
TAVILY_API_KEY=your_api_key_here
BRAVE_API_KEY=your_api_key_here

# TTS (optional)
ELEVENLABS_API_KEY=your_api_key_here
